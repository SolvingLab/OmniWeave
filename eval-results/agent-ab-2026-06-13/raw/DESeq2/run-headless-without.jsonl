{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PxUfGCbv8wRFNsZQHUyg29","type":"tool_result","content":"498\t          estimateSizeFactors.DESeqDataSet)\n499\t\n500\testimateDispersions.DESeqDataSet <- function(object, fitType=c(\"parametric\",\"local\",\"mean\", \"glmGamPoi\"),\n501\t                                             maxit=100, useCR=TRUE,\n502\t                                             weightThreshold=1e-2,\n503\t                                             quiet=FALSE, modelMatrix=NULL,\n504\t                                             minmu=if (fitType==\"glmGamPoi\") 1e-6 else 0.5) {\n505\t  # Temporary hack for backward compatibility with \"old\" DESeqDataSet\n506\t  # objects. Remove once all serialized DESeqDataSet objects around have\n507\t  # been updated.\n508\t  if (!.hasSlot(object, \"rowRanges\"))\n509\t    object <- updateObject(object)\n510\t  if (is.null(sizeFactors(object)) & is.null(normalizationFactors(object))) {\n511\t    stop(\"first call estimateSizeFactors or provide a normalizationFactor matrix before estimateDispersions\")\n512\t  }\n513\t  # size factors could have slipped in to colData from a previous run\n514\t  if (!is.null(sizeFactors(object))) {\n515\t    if (!is.numeric(sizeFactors(object))) {\n516\t      stop(\"the sizeFactor column in colData is not numeric.\n517\tthis column could have come in during colData import and should be removed.\")\n518\t    }\n519\t    if (any(is.na(sizeFactors(object)))) {\n520\t      stop(\"the sizeFactor column in colData contains NA.\n521\tthis column could have come in during colData import and should be removed.\")\n522\t    }\n523\t  }\n524\t\n525\t  # match argument for fitType\n526\t  fitType <- match.arg(fitType, choices=c(\"parametric\",\"local\",\"mean\", \"glmGamPoi\"))\n527\t  "}]},"parent_tool_use_id":null,"session_id":"baf8919e-1e86-4446-a688-d472f8328d4c","uuid":"3ba6896d-70a7-4ec0-a1cd-d3df79d2d54b","timestamp":"2026-06-13T14:26:53.128Z","tool_use_result":{"type":"text","file":{"filePath":"/private/tmp/omniweave-corpus/DESeq2/R/methods.R","content":"          estimateSizeFactors.DESeqDataSet)\n\nestimateDispersions.DESeqDataSet <- function(object, fitType=c(\"parametric\",\"local\",\"mean\", \"glmGamPoi\"),\n                                             maxit=100, useCR=TRUE,\n                                             weightThreshold=1e-2,\n                                             quiet=FALSE, modelMatrix=NULL,\n                                             minmu=if (fitType==\"glmGamPoi\") 1e-6 else 0.5) {\n  # Temporary hack for backward compatibility with \"old\" DESeqDataSet\n  # objects. Remove once all serialized DESeqDataSet objects around have\n  # been updated.\n  if (!.hasSlot(object, \"rowRanges\"))\n    object <- updateObject(object)\n  if (is.null(sizeFactors(object)) & is.null(normalizationFactors(object))) {\n    stop(\"first call estimateSizeFactors or provide a normalizationFactor matrix before estimateDispersions\")\n  }\n  # size factors could have slipped in to colData from a previous run\n  if (!is.null(sizeFactors(object))) {\n    if (!is.numeric(sizeFactors(object))) {\n      stop(\"the sizeFactor column in colData is not numeric.\nthis column could have come in during colData import and should be removed.\")\n    }\n    if (any(is.na(sizeFactors(object)))) {\n      stop(\"the sizeFactor column in colData contains NA.\nthis column could have come in during colData import and should be removed.\")\n    }\n  }\n\n  # match argument for fitType\n  fitType <- match.arg(fitType, choices=c(\"parametric\",\"local\",\"mean\", \"glmGamPoi\"))\n  ","numLines":30,"startLine":498,"totalLines":884}}}
