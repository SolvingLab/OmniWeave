{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_9fb125dc223642e3b80c44cf","type":"tool_result","content":"1\t\"\"\"\n2\tDjango's standard crypto functions and utilities.\n3\t\"\"\"\n4\t\n5\timport hashlib\n6\timport hmac\n7\timport secrets\n8\timport warnings\n9\t\n10\tfrom django.conf import settings\n11\tfrom django.utils.deprecation import RemovedInDjango70Warning\n12\tfrom django.utils.encoding import force_bytes\n13\tfrom django.utils.warnings import django_file_prefixes\n14\t\n15\t\n16\tclass InvalidAlgorithm(ValueError):\n17\t    \"\"\"Algorithm is not supported by hashlib.\"\"\"\n18\t\n19\t    pass\n20\t\n21\t\n22\t# RemovedInDjango70Warning: algorithm=\"sha256\"\n23\tdef salted_hmac(key_salt, value, secret=None, *, algorithm=None):\n24\t    \"\"\"\n25\t    Return the HMAC of 'value', using a key generated from key_salt and a\n26\t    secret (which defaults to settings.SECRET_KEY). Default algorithm is SHA1,\n27\t    but any algorithm name supported by hashlib can be passed.\n28\t\n29\t    Removed in Django70Warning: The default algorithm will change to SHA256\n30\t    in Django 7.0, so provide an explicit algorithm to silence the warning.\n31\t\n32\t    A different key_salt should be passed in for every application of HMAC.\n33\t    \"\"\"\n34\t    if algorithm is None:\n35\t        warnings.warn(\n36\t            \"The default argument for algorithm in salted_hmac() will change \"\n37\t            \"from 'sha1' to 'sha256' in Django 7.0. Pass an explicit \"\n38\t            \"algorithm to silence this warning.\",\n39\t            category=RemovedInDjango70Warning,\n40\t            skip_file_prefixes=django_file_prefixes(),\n41\t        )\n42\t        algorithm = \"sha1\"\n43\t    if secret is None:\n44\t        secret = settings.SECRET_KEY\n45\t\n46\t    key_salt = force_bytes(key_salt)\n47\t    secret = force_bytes(secret)\n48\t    try:\n49\t        hasher = getattr(hashlib, algorithm)\n50\t    except AttributeError as e:\n51\t        raise InvalidAlgorithm(\n52\t            \"%r is not an algorithm accepted by the hashlib module.\" % algorithm\n53\t        ) from e\n54\t    # We need to generate a derived key from our base key. We can do this by\n55\t    # passing the key_salt and our base key through a pseudo-random function.\n56\t    key = hasher(key_salt + secret).digest()\n57\t    # If len(key_salt + secret) > block size of the hash algorithm, the above\n58\t    # line is redundant and could be replaced by key = key_salt + secret, since\n59\t    # the hmac module does the same thing for keys longer than the block size.\n60\t    # However, we need to ensure that we *always* do this.\n61\t    return hmac.new(key, msg=force_bytes(value), digestmod=hasher)\n62\t\n63\t\n64\tRANDOM_STRING_CHARS = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n65\t\n66\t\n67\tdef get_random_string(length, allowed_chars=RANDOM_STRING_CHARS):\n68\t    \"\"\"\n69\t    Return a securely generated random string.\n70\t\n71\t    The bit length of the returned value can be calculated with the formula:\n72\t        log_2(len(allowed_chars)^length)\n73\t\n74\t    For example, with default `allowed_chars` (26+26+10), this gives:\n75\t      * length: 12, bit length =~ 71 bits\n76\t      * length: 22, bit length =~ 131 bits\n77\t    \"\"\"\n78\t    return \"\".join(secrets.choice(allowed_chars) for i in range(length))\n79\t\n80\t\n81\tdef constant_time_compare(val1, val2):\n82\t    \"\"\"Return True if the two strings are equal, False otherwise.\"\"\"\n83\t    return secrets.compare_digest(force_bytes(val1), force_bytes(val2))\n84\t\n85\t\n86\tdef pbkdf2(password, salt, iterations, dklen=0, digest=None):\n87\t    \"\"\"Return the hash of password using pbkdf2.\"\"\"\n88\t    if digest is None:\n89\t        digest = hashlib.sha256\n90\t    dklen = dklen or None\n91\t    password = force_bytes(password)\n92\t    salt = force_bytes(salt)\n93\t    return hashlib.pbkdf2_hmac(digest().name, password, salt, iterations, dklen)\n94\t"}]},"parent_tool_use_id":null,"session_id":"f43d2757-8e7f-47d8-b40b-592ff757e44b","uuid":"af23183c-c0ab-4d9c-80ac-aa25abd17317","timestamp":"2026-06-24T05:25:41.056Z","tool_use_result":{"type":"text","file":{"filePath":"/private/tmp/step-a-b9ID/target/django/utils/crypto.py","content":"\"\"\"\nDjango's standard crypto functions and utilities.\n\"\"\"\n\nimport hashlib\nimport hmac\nimport secrets\nimport warnings\n\nfrom django.conf import settings\nfrom django.utils.deprecation import RemovedInDjango70Warning\nfrom django.utils.encoding import force_bytes\nfrom django.utils.warnings import django_file_prefixes\n\n\nclass InvalidAlgorithm(ValueError):\n    \"\"\"Algorithm is not supported by hashlib.\"\"\"\n\n    pass\n\n\n# RemovedInDjango70Warning: algorithm=\"sha256\"\ndef salted_hmac(key_salt, value, secret=None, *, algorithm=None):\n    \"\"\"\n    Return the HMAC of 'value', using a key generated from key_salt and a\n    secret (which defaults to settings.SECRET_KEY). Default algorithm is SHA1,\n    but any algorithm name supported by hashlib can be passed.\n\n    Removed in Django70Warning: The default algorithm will change to SHA256\n    in Django 7.0, so provide an explicit algorithm to silence the warning.\n\n    A different key_salt should be passed in for every application of HMAC.\n    \"\"\"\n    if algorithm is None:\n        warnings.warn(\n            \"The default argument for algorithm in salted_hmac() will change \"\n            \"from 'sha1' to 'sha256' in Django 7.0. Pass an explicit \"\n            \"algorithm to silence this warning.\",\n            category=RemovedInDjango70Warning,\n            skip_file_prefixes=django_file_prefixes(),\n        )\n        algorithm = \"sha1\"\n    if secret is None:\n        secret = settings.SECRET_KEY\n\n    key_salt = force_bytes(key_salt)\n    secret = force_bytes(secret)\n    try:\n        hasher = getattr(hashlib, algorithm)\n    except AttributeError as e:\n        raise InvalidAlgorithm(\n            \"%r is not an algorithm accepted by the hashlib module.\" % algorithm\n        ) from e\n    # We need to generate a derived key from our base key. We can do this by\n    # passing the key_salt and our base key through a pseudo-random function.\n    key = hasher(key_salt + secret).digest()\n    # If len(key_salt + secret) > block size of the hash algorithm, the above\n    # line is redundant and could be replaced by key = key_salt + secret, since\n    # the hmac module does the same thing for keys longer than the block size.\n    # However, we need to ensure that we *always* do this.\n    return hmac.new(key, msg=force_bytes(value), digestmod=hasher)\n\n\nRANDOM_STRING_CHARS = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n\n\ndef get_random_string(length, allowed_chars=RANDOM_STRING_CHARS):\n    \"\"\"\n    Return a securely generated random string.\n\n    The bit length of the returned value can be calculated with the formula:\n        log_2(len(allowed_chars)^length)\n\n    For example, with default `allowed_chars` (26+26+10), this gives:\n      * length: 12, bit length =~ 71 bits\n      * length: 22, bit length =~ 131 bits\n    \"\"\"\n    return \"\".join(secrets.choice(allowed_chars) for i in range(length))\n\n\ndef constant_time_compare(val1, val2):\n    \"\"\"Return True if the two strings are equal, False otherwise.\"\"\"\n    return secrets.compare_digest(force_bytes(val1), force_bytes(val2))\n\n\ndef pbkdf2(password, salt, iterations, dklen=0, digest=None):\n    \"\"\"Return the hash of password using pbkdf2.\"\"\"\n    if digest is None:\n        digest = hashlib.sha256\n    dklen = dklen or None\n    password = force_bytes(password)\n    salt = force_bytes(salt)\n    return hashlib.pbkdf2_hmac(digest().name, password, salt, iterations, dklen)\n","numLines":94,"startLine":1,"totalLines":94}}}
